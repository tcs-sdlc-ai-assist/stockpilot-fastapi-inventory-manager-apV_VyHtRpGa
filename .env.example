# StockPilot Environment Configuration
# Copy this file to .env and update the values for your environment.

# ============================================================
# APPLICATION SECRET KEY
# ============================================================
# Used for signing JWT tokens and other cryptographic operations.
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# ============================================================
# DEFAULT ADMIN CREDENTIALS
# ============================================================
# ⚠️  SECURITY WARNING: Change these default credentials immediately
# in production! Leaving defaults in place is a critical security risk.
# These are used to create the initial admin user on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_DISPLAY_NAME=Administrator

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./stockpilot.db
#
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockpilot